{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ShellVM": {
    "MaxConcurrentSessions": 32,
    "MaxIdleSessionSeconds": 1800,
    "DefaultShell": "/bin/sh",
    "AllowedShells": ["/bin/sh", "/bin/bash", "python3", "ape"],
    "OutputRingBufferLines": 10000,
    "CommandTimeoutSeconds": 600,
    "AuditEnabled": true,
    "SandboxCpuPercent": 80,
    "SandboxMemoryMb": 2048,
    "HttpEndpoint": "http://shell-vm:5950",
    "WsEndpoint": "ws://shell-vm:6950",
    "BlockControllerUrl": "http://block-controller:5100",
    "RedisConnectionString": "redis:6379",
    "PostgresConnectionString": "Host=postgres;Port=5432;Database=mls_db;Username=mls_user;Password=mls"
  }
}

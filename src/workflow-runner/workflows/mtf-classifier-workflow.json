{
  "name": "mtf-classifier-workflow",
  "cycles": 1,
  "symbols": [
    "BTC-USDT",
    "ETH-USDT",
    "ARB-USDT",
    "SOL-USDT"
  ],
  "timeframes": ["1m", "5m", "15m", "1h", "4h", "1D"],
  "steps": [
    "price-check",
    "market-conditions",
    "mtf-classifier-training",
    "model-evaluation",
    "retrain-decision"
  ],
  "block_controller_url": "http://localhost:5100",
  "designer_url": "http://localhost:5250",
  "data_layer_url": "http://localhost:5700",
  "step_params": {
    "mtf-classifier-training": {
      "model_type": "model-t",
      "ensemble": true,
      "mtf_symbols": ["BTC-USDT", "ETH-USDT", "ARB-USDT", "SOL-USDT"],
      "mtf_timeframes": ["1m", "5m", "15m", "1h", "4h", "1D"],
      "hyperparams": {
        "epochs": 100,
        "batch_size": 256,
        "learning_rate": 0.001,
        "dropout_rate": 0.2,
        "hidden_dims": [128, 64],
        "fusion_dim": 64,
        "weight_decay": 1e-5,
        "early_stopping_patience": 20,
        "n_classes": 3
      },
      "per_symbol_training": true,
      "onnx_expected_input_shape": [1, 6, 8],
      "onnx_expected_output_shape": [1, 3]
    },
    "retrain-decision": {
      "model_type": "model-t",
      "force_retrain": false
    }
  },
  "retrain_gate": {
    "min_accuracy": 0.68,
    "min_f1": 0.63,
    "max_epochs_no_improve": 20,
    "retrain_interval_cycles": 3
  }
}

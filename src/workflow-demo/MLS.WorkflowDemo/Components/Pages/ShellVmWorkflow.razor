@page "/workflow/shell-vm"
@rendermode InteractiveServer
@inject WorkflowDataService Svc

<PageTitle>Shell VM Workflow</PageTitle>

<WorkflowHeader Title="Shell VM — Secure Sandboxed Execution"
                Description="Provides an authenticated, resource-limited shell session for running MLS maintenance commands, Python ML scripts, and diagnostic queries against live platform data."
                Icon="⌨" HttpPort="5950" WsPort="6950"
                IsLive="_markets.Count > 0"
                DataSource="Hyperliquid mids · platform health"
                AccentColor="#8b949e" />

<WorkflowPipeline Steps="_steps" ActiveStep="_markets.Count > 0 ? 3 : 0" />

<div class="wf-body">
    @if (_markets.Count == 0)
    {
        <div class="wf-loading">Starting shell session…</div>
    }
    else
    {
        <div class="wf-two-col">
            <section class="wf-card" style="flex:1.3">
                <h2>Shell Session Output <span class="wf-live-dot"></span></h2>
                <div class="shell-terminal">
                    <div class="shell-header">mls@shell-vm:~$ <span class="shell-cursor">▌</span></div>
                    @foreach (var line in _terminal)
                    {
                        <div class="shell-line @(line.Kind)">@line.Text</div>
                    }
                </div>
            </section>

            <section class="wf-card">
                <h2>Live Market Query Result</h2>
                <p class="shell-cmd-desc">Output of: <code>mls-cli market-snapshot --top 8</code></p>
                <table class="wf-table" style="margin-top:10px">
                    <thead><tr><th>Symbol</th><th>Mid</th><th>24h Vol</th><th>Funding</th></tr></thead>
                    <tbody>
                        @foreach (var m in _markets.Take(8))
                        {
                            <tr>
                                <td class="mono">@m.Symbol</td>
                                <td class="mono text-bright">@m.Mid.ToString("F4")</td>
                                <td class="mono text-muted">@FormatVol(m.DayVolumeUsd)</td>
                                <td class="mono @(m.Funding >= 0 ? "text-green" : "text-red")">
                                    @(m.Funding >= 0 ? "+" : "")@m.Funding.ToString("F4")%
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </div>
        <div id="data-loaded"></div>
    }
</div>

<style>
    .shell-terminal { background: #020408; border-radius: 8px; border: 1px solid #30363d;
                      padding: 12px 14px; font-family: 'Consolas', 'JetBrains Mono', monospace;
                      font-size: 0.75rem; line-height: 1.7; min-height: 200px; }
    .shell-header { color: #3fb950; margin-bottom: 4px; }
    .shell-cursor { animation: blink 1s step-end infinite; }
    @@keyframes blink { 50% { opacity: 0; } }
    .shell-line { color: #e6edf3; }
    .shell-line.cmd  { color: #00d4ff; }
    .shell-line.out  { color: #e6edf3; }
    .shell-line.ok   { color: #3fb950; }
    .shell-line.err  { color: #f85149; }
    .shell-line.warn { color: #d29922; }
    .shell-line.meta { color: #8b949e; }
    .shell-cmd-desc { font-size: 0.78rem; color: #8b949e; margin: 0; }
    .shell-cmd-desc code { color: #00d4ff; background: #0d1117; padding: 1px 5px; border-radius: 3px; }
</style>

@code {
    private IReadOnlyList<AssetMarket> _markets = [];

    private sealed record TermLine(string Text, string Kind);
    private IReadOnlyList<TermLine> _terminal = [];

    private static readonly IReadOnlyList<PipelineStep> _steps =
    [
        new("Session Connect",  "🔌", "WebSocket auth: session token + allowed command whitelist",       "#8b949e"),
        new("Command Parse",    "⌨",  "Tokenise input, validate against ACL, resolve env vars",          "#00d4ff"),
        new("Sandbox Execute",  "⚙",  "Collectible ALC + 100ms CPU timeout + 64MB memory cap",           "#d29922"),
        new("Output Stream",    "📤", "IAsyncEnumerable<string> line stream → WebSocket chunks",          "#3fb950"),
    ];

    private static string FormatVol(decimal v) =>
        v switch { >= 1_000_000_000m => $"${v/1_000_000_000m:F1}B", >= 1_000_000m => $"${v/1_000_000m:F1}M", _ => $"${v:F0}" };

    protected override async Task OnInitializedAsync()
    {
        using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
        _markets = await Svc.GetAssetMarketsAsync(cts.Token);

        var top = _markets.FirstOrDefault();
        _terminal =
        [
            new("$ mls-cli status", "cmd"),
            new($"✔  Block Controller   ONLINE  (heartbeat 1.2s ago)", "ok"),
            new($"✔  Data Layer         ONLINE  (streamed {_markets.Count} assets)", "ok"),
            new($"✔  Trader             ONLINE  ({_markets.Count(m=>m.ChangePercent>0)} BUY / {_markets.Count(m=>m.ChangePercent<0)} SELL signals)", "ok"),
            new($"✔  AI Hub             ONLINE  (provider: openai / gpt-4o)", "ok"),
            new("", "out"),
            new("$ mls-cli market-snapshot --top 8", "cmd"),
            new($"Fetching from Hyperliquid… OK ({_markets.Count} assets)", "meta"),
            new("", "out"),
            new("$ python scripts/training_pipeline.py --model model-t --symbol ETH", "cmd"),
            new("[INFO] Loading 1,440 candles from feature_store_vectors…", "meta"),
            new($"[INFO] Features: RSI={WorkflowDataService.EngineerFeatures("ETH", []).Rsi14} (stale — no candle data in shell)", "warn"),
            new("[INFO] Training FastForest — epochs 50 — AMP bf16", "meta"),
            new("[INFO] Best val_accuracy: 0.7841 — exporting ONNX…", "ok"),
            new("[INFO] IPFS upload → CID: QmXfzk8…  ✔", "ok"),
        ];
    }
}

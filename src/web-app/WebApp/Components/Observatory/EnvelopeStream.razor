@inject IBlockControllerHub Hub
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="envelope-stream">

    @* ── Header ─────────────────────────────────────────────────────────── *@
    <div class="es-header">
        <div class="es-header-left">
            <span class="es-icon" style="color:#00d4ff">≋</span>
            <span class="es-title">Envelope Stream</span>
            <div class="live-dot"></div>
        </div>
        <div class="es-header-right">
            <span class="es-count">@_buffer.Count / @MaxBuffer</span>
            <FluentButton Appearance="Appearance.Stealth" @onclick="ClearBuffer" class="es-clear-btn">
                Clear
            </FluentButton>
        </div>
    </div>

    <div class="es-accent-bar"></div>

    @* ── Filters ─────────────────────────────────────────────────────────── *@
    <div class="es-filters">
        <div class="es-filter-input-wrap">
            <span class="es-filter-icon">⌕</span>
            <input class="es-filter-input"
                   type="text"
                   placeholder="Regex filter (e.g. TRADE_.*)…"
                   @bind="_regexFilter"
                   @bind:event="oninput" />
            @if (_regexError is not null)
            {
                <span class="es-regex-error" title="@_regexError">⚠</span>
            }
        </div>

        @* Category chip filters *@
        <div class="es-chips">
            @foreach (var cat in _categories)
            {
                var c = cat;
                <button class="es-chip @(_activeCategories.Contains(c) ? "es-chip--active" : "")"
                        @onclick="() => ToggleCategory(c)">
                    <span class="es-chip-dot" style="background:@GetCategoryColor(c)"></span>
                    @c
                </button>
            }
        </div>
    </div>

    @* ── Envelope rows ────────────────────────────────────────────────────── *@
    <div class="es-scroll" id="es-scroll-@_id">
        @foreach (var entry in FilteredEntries())
        {
            <div class="es-row" @key="entry.EntryId">
                <span class="es-ts mono">@entry.Timestamp.ToString("HH:mm:ss.fff")</span>
                <span class="es-type-badge" style="background:@(GetCategoryColor(GetCategory(entry.Type)) + "22"); border-color:@(GetCategoryColor(GetCategory(entry.Type)) + "44"); color:@GetCategoryColor(GetCategory(entry.Type))">
                    @entry.Type
                </span>
                <span class="es-module mono">@entry.ModuleId</span>
                <span class="es-summary">@entry.PayloadSummary</span>
            </div>
        }
        @if (!FilteredEntries().Any())
        {
            <div class="es-empty">No envelopes match the current filter</div>
        }
    </div>
</div>

<style>
    .envelope-stream {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: var(--mls-surface, #0e1018);
        overflow: hidden;
    }

    .es-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        background: var(--mls-surface-2, #131620);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        flex-shrink: 0;
    }
    .es-header-left { display: flex; align-items: center; gap: 7px; }
    .es-header-right { display: flex; align-items: center; gap: 8px; }
    .es-icon { font-size: 1rem; }
    .es-title { font-weight: 700; font-size: 0.82rem; color: var(--mls-text, #e2e8f0); }
    .es-count { font-size: 0.68rem; color: rgba(255,255,255,0.25); font-family: var(--font-mono, monospace); }
    .es-clear-btn { font-size: 0.68rem !important; padding: 2px 8px !important; }

    .es-accent-bar {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(0,212,255,0.35), transparent);
        flex-shrink: 0;
    }

    .es-filters {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 8px 12px;
        background: var(--mls-surface-2, #131620);
        border-bottom: 1px solid rgba(255,255,255,0.04);
        flex-shrink: 0;
    }
    .es-filter-input-wrap {
        display: flex;
        align-items: center;
        gap: 7px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 6px;
        padding: 5px 10px;
    }
    .es-filter-icon { color: rgba(255,255,255,0.2); font-size: 0.9rem; }
    .es-filter-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--mls-text, #e2e8f0);
        font-size: 0.75rem;
        font-family: var(--font-mono, monospace);
    }
    .es-filter-input::placeholder { color: rgba(255,255,255,0.15); }
    .es-regex-error { color: #f43f5e; font-size: 0.75rem; cursor: help; }

    .es-chips { display: flex; gap: 4px; flex-wrap: wrap; }
    .es-chip {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.63rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.35);
        cursor: pointer;
        transition: all 0.15s;
    }
    .es-chip:hover { color: rgba(255,255,255,0.7); }
    .es-chip--active { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.15); color: #e2e8f0; }
    .es-chip-dot { width: 5px; height: 5px; border-radius: 50%; }

    .es-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 4px 0;
        font-size: 0.72rem;
    }
    .es-row {
        display: flex;
        align-items: baseline;
        gap: 8px;
        padding: 4px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.02);
        transition: background 0.1s;
    }
    .es-row:hover { background: rgba(255,255,255,0.02); }

    .es-ts {
        font-size: 0.65rem;

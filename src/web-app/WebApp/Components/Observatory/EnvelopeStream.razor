        animation: live-pulse 1.5s ease-in-out infinite;
    }
    @@keyframes live-pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
</style>

@code {
    private const int MaxBuffer = 500;

    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private readonly List<EnvelopeEntry> _buffer = new(MaxBuffer);
    private string _regexFilter = "";
    private string? _regexError;
    private readonly HashSet<string> _activeCategories = new(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource _cts = new();

    private static readonly string[] _categories = ["Trading", "Arbitrage", "DeFi", "ML", "System", "AI", "Shell", "Other"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Subscribe to all topics by passing empty array
        await foreach (var envelope in Hub
            .GetEnvelopeStreamAsync([], _cts.Token)
            .ConfigureAwait(false))
        {
            var payloadSummary = envelope.Payload.GetRawText();
            if (payloadSummary.Length > 120) payloadSummary = payloadSummary[..120] + "…";

            var entry = new EnvelopeEntry(
                EntryId:        Guid.NewGuid(),
                Timestamp:      DateTimeOffset.UtcNow,
                Type:           envelope.Type ?? "UNKNOWN",
                ModuleId:       envelope.ModuleId ?? "—",
                PayloadSummary: payloadSummary);

            if (_buffer.Count >= MaxBuffer) _buffer.RemoveAt(0);
            _buffer.Add(entry);

            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private IEnumerable<EnvelopeEntry> FilteredEntries()
    {
        IEnumerable<EnvelopeEntry> result = _buffer;

        // Category filter
        if (_activeCategories.Count > 0)
            result = result.Where(e => _activeCategories.Contains(GetCategory(e.Type)));

        // Regex filter
        if (!string.IsNullOrWhiteSpace(_regexFilter))
        {
            try
            {
                var rx = new System.Text.RegularExpressions.Regex(
                    _regexFilter,
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase,
                    TimeSpan.FromMilliseconds(50));
                _regexError = null;
                result = result.Where(e => rx.IsMatch(e.Type));
            }
            catch (System.Text.RegularExpressions.RegexParseException ex)
            {
                _regexError = ex.Message;
            }
        }

        return result.Reverse(); // newest first
    }

    private void ToggleCategory(string category)
    {
        if (!_activeCategories.Remove(category))
            _activeCategories.Add(category);
    }

    private void ClearBuffer() => _buffer.Clear();

    private static string GetCategory(string type) => type switch
    {
        var t when t.StartsWith("TRADE") || t.StartsWith("ORDER") || t.StartsWith("POSITION") => "Trading",
        var t when t.StartsWith("ARB")                                                          => "Arbitrage",
        var t when t.StartsWith("DEFI") || t.StartsWith("HEALTH")                              => "DeFi",
        var t when t.StartsWith("TRAINING") || t.StartsWith("INFERENCE") || t.StartsWith("MODEL") => "ML",
        var t when t.StartsWith("MODULE")   || t.StartsWith("ENVELOPE")  || t.StartsWith("STRATEGY") => "System",
        var t when t.StartsWith("AI")                                                           => "AI",
        var t when t.StartsWith("SHELL")                                                        => "Shell",
        _                                                                                       => "Other",
    };

    private static string GetCategoryColor(string category) => category switch
    {
        "Trading"   => "#00d4ff",
        "Arbitrage" => "#f59e0b",
        "DeFi"      => "#22c55e",
        "ML"        => "#7c3aed",
        "System"    => "#64748b",
        "AI"        => "#ec4899",
        "Shell"     => "#f43f5e",
        _           => "#94a3b8",
    };

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync().ConfigureAwait(false);
        _cts.Dispose();
    }

    private sealed record EnvelopeEntry(
        Guid EntryId,
        DateTimeOffset Timestamp,
        string Type,
        string ModuleId,
        string PayloadSummary);
}

@* Block palette — categorized accordion of all registered block types *@

<div class="block-palette">
    <div class="palette-header">
        <span class="palette-title">Block Palette</span>
        <FluentButton Appearance="Appearance.Stealth"
                     
                      @onclick="() => OnClose.InvokeAsync()"
                      title="Close palette" />
    </div>

    <div class="palette-search">
        <FluentSearch Placeholder="Search blocks…"
                      @bind-Value="_search"
                      @bind-Value:after="StateHasChanged" />
    </div>

    <div class="palette-body">
        @foreach (var category in FilteredCategories())
        {
            <details class="palette-category" open>
                <summary class="category-header">
                    <span class="category-badge" style="background:@category.Color">@category.ShortLabel</span>
                    @category.Label
                </summary>
                <div class="category-items">
                    @foreach (var block in category.Blocks)
                    {
                        var b = block;
                        <div class="palette-item"
                             draggable="true"
                             @ondragstart="() => OnBlockDragStart.InvokeAsync(b.TypeKey)"
                             @onclick="() => OnBlockDragStart.InvokeAsync(b.TypeKey)"
                             title="@b.Description">
                            <span class="pi-name">@b.DisplayName</span>
                            @if (!string.IsNullOrEmpty(b.Description))
                            {
                                <span class="pi-desc">@b.Description</span>
                            }
                        </div>
                    }
                </div>
            </details>
        }
    </div>
</div>

<style>
    .block-palette {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 220px;
        background: var(--neutral-layer-3, #1c2128);
        border-right: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        z-index: 10;
        overflow: hidden;
    }

    .palette-header {
        display: flex;
        align-items: center;
        padding: 8px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        gap: 8px;
        flex-shrink: 0;
    }

    .palette-title {
        flex: 1;
        font-weight: 600;
        font-size: 0.78rem;
        color: #e6edf3;
    }

    .palette-search {
        padding: 6px 8px;
        flex-shrink: 0;
    }

    .palette-body {
        flex: 1;
        overflow-y: auto;
        padding: 4px 0;
    }

    .palette-category {
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .category-header {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        cursor: pointer;
        font-size: 0.72rem;
        font-weight: 600;
        color: #8b949e;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        list-style: none;
        user-select: none;
    }

    .category-header:hover { color: #e6edf3; background: rgba(255,255,255,0.04); }

    .category-badge {
        font-size: 0.58rem;
        padding: 1px 4px;
        border-radius: 2px;
        color: #fff;
        font-weight: 700;
    }

    .category-items { padding: 2px 0; }

    .palette-item {
        padding: 5px 12px 5px 20px;
        cursor: grab;
        display: flex;
        flex-direction: column;
        gap: 1px;
        border-radius: 4px;
        margin: 1px 4px;
        transition: background 0.12s;
    }

    .palette-item:hover { background: rgba(0,212,255,0.08); }
    .palette-item:active { cursor: grabbing; }

    .pi-name {
        font-size: 0.74rem;
        color: #e6edf3;
        white-space: nowrap;
    }

    .pi-desc {
        font-size: 0.64rem;
        color: #6e7681;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {

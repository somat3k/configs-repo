        ]),
        new("Risk / Execution", "EXEC", "#7c3f00",
        [
            new("PositionSizerBlock",  "Position Sizer",   "Kelly / fixed-risk sizing"),
            new("StopLossBlock",       "Stop Loss",        "Dynamic stop management"),
            new("DrawdownGuardBlock",  "Drawdown Guard",   "Max drawdown circuit break"),
            new("ExposureLimitBlock",  "Exposure Limit",   "Portfolio exposure cap"),
            new("OrderEmitterBlock",   "Order Emitter",    "Submit orders to broker"),
            new("OrderRouterBlock",    "Order Router",     "Route to best venue"),
        ]),
        new("Arbitrage", "ARB", "#9e5a00",
        [
            new("SpreadCalculatorBlock", "Spread Calc",     "Cross-exchange spread"),

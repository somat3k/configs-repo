            new("TradeFeedBlock",      "Trade Feed",      "Real-time trade ticks"),
            new("BacktestReplayBlock", "Backtest Replay", "Historical candle replay"),
            new("FeedSourceBlock",     "Feed Source",     "Hydra data source"),
        ]),
        new("Indicators", "IND", "#0a7c7c",
        [
            new("RSIBlock",           "RSI",              "Relative Strength Index"),
            new("MACDBlock",          "MACD",             "Moving Average Convergence"),
            new("BollingerBlock",     "Bollinger Bands",  "Volatility envelope"),
            new("ATRBlock",           "ATR",              "Average True Range"),
            new("VWAPBlock",          "VWAP",             "Volume Weighted Avg Price"),
            new("VolumeProfileBlock", "Volume Profile",   "Volume by price level"),
            new("CustomIndicatorBlock","Custom Indicator","User-defined indicator"),
        ]),
        new("ML Models", "ML", "#6b2fa0",
        [
            new("ModelTInferenceBlock", "Model-T Inference", "Trading model inference"),
            new("ModelAInferenceBlock", "Model-A Inference", "Arbitrage model inference"),
            new("ModelDInferenceBlock", "Model-D Inference", "DeFi model inference"),
            new("EnsembleBlock",        "Ensemble",          "Multi-model ensemble"),
        ]),
        new("Strategy", "STRAT", "#2d5a27",
        [

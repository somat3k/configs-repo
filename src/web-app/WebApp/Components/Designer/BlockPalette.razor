    [Parameter] public EventCallback OnClose { get; set; }

    private string _search = string.Empty;

    private record BlockEntry(string TypeKey, string DisplayName, string Description = "");

    private record CategoryEntry(string Label, string ShortLabel, string Color, BlockEntry[] Blocks);


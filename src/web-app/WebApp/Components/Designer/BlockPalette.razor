            new("DataLoaderBlock",       "Data Loader",    "Load training dataset"),
            new("FeatureEngineerBlock",  "Feature Engineer","Feature engineering"),
            new("TrainSplitBlock",       "Train/Val Split", "Train/validation split"),
            new("TrainModelBlock",       "Train Model",     "Launch training job"),
            new("ValidateModelBlock",    "Validate Model",  "Validation metrics"),
            new("ExportONNXBlock",       "Export ONNX",     "Export to ONNX runtime"),
            new("HyperparamSearchBlock", "Hyperparam Search","Hyperparameter sweep"),
        ]),
    ];

    private IEnumerable<CategoryEntry> FilteredCategories()
    {
        if (string.IsNullOrWhiteSpace(_search))
            return AllCategories;

        return AllCategories
            .Select(c => c with
            {
                Blocks = c.Blocks.Where(b =>
                    b.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    b.Description.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToArray(),
            })
            .Where(c => c.Blocks.Length > 0)
            .ToArray();
    }
}

        [
            new("MorphoSupplyBlock",    "Morpho Supply",    "Morpho lending supply"),
            new("MorphoBorrowBlock",    "Morpho Borrow",    "Morpho borrow position"),
            new("BalancerSwapBlock",    "Balancer Swap",    "Balancer AMM swap"),
            new("CollateralHealthBlock","Collateral Health","Collateral health check"),
            new("YieldOptimizerBlock",  "Yield Optimizer",  "Auto yield routing"),
            new("LiquidationGuardBlock","Liquidation Guard","Liquidation prevention"),
            new("LendingHealthBlock",   "Lending Health",   "HF/LTV monitor"),
        ]),
        new("ML Training", "TRAIN", "#831843",

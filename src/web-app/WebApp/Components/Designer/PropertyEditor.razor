@using MLS.Core.Designer
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@implements IAsyncDisposable

@* Property editor — slides in from the right when a block is selected *@

<div class="property-editor">
    <div class="pe-header">
        <span class="pe-title">@Block.BlockType</span>
        <FluentButton Appearance="Appearance.Stealth"
                     
                      @onclick="() => OnClose.InvokeAsync()"
                      title="Close" />
    </div>

    <div class="pe-body">
        <div class="pe-section-label">Block ID</div>
        <code class="pe-id">@Block.BlockId.ToString()[..8]…</code>

        <div class="pe-section-label">Input Sockets</div>
        @if (Block.InputSockets.Count == 0)
        {
            <p class="pe-empty">No input sockets</p>
        }
        else
        {
            @foreach (var s in Block.InputSockets)
            {
                <div class="pe-socket">
                    <span class="socket-dot" style="background:@GetSocketColor(s.SocketType)" />
                    <span>@s.Name</span>
                    <span class="pe-socket-type">@s.SocketType</span>
                </div>
            }
        }

        <div class="pe-section-label">Output Sockets</div>
        @if (Block.OutputSockets.Count == 0)
        {
            <p class="pe-empty">No output sockets</p>
        }
        else
        {
            @foreach (var s in Block.OutputSockets)
            {
                <div class="pe-socket">
                    <span class="socket-dot" style="background:@GetSocketColor(s.SocketType)" />
                    <span>@s.Name</span>
                    <span class="pe-socket-type">@s.SocketType</span>
                </div>
            }
        }

        @* Typed parameter inputs rendered by type *@
        @if (_parameters.Count > 0)
        {
            <div class="pe-section-label">Parameters</div>
            @foreach (var param in _parameters)
            {
                var p = param;
                <div class="pe-param">
                    <label class="pe-param-label">@p.Name</label>
                    @if (p.Type == ParameterType.Bool)
                    {
                        <FluentCheckbox @bind-Value="@p.BoolValue" Label="@p.Name" />
                    }
                    else if (p.Type == ParameterType.Enum)
                    {
                        <FluentSelect TOption="string" @bind-Value="@p.StringValue">
                            @foreach (var opt in p.Options)
                            {
                                <FluentOption TOption="string" Value="@opt">@opt</FluentOption>
                            }
                        </FluentSelect>
                    }
                    else
                    {
                        <FluentTextField @bind-Value="@p.StringValue"
                                         Placeholder="@p.DefaultValue"
                                         InputMode="@(p.Type == ParameterType.Int || p.Type == ParameterType.Float ? InputMode.Numeric : InputMode.None)" />
                    }
                    @if (!string.IsNullOrEmpty(p.Description))
                    {
                        <span class="pe-param-hint">@p.Description</span>
                    }
                </div>
            }
        }

        @* Monaco code editor — shown only for CustomIndicatorBlock *@
        @if (Block.BlockType == "CustomIndicatorBlock")
        {
            <div class="pe-section-label">C# Code</div>
            <div class="pe-code-editor" @ref="_editorContainer" id="@_editorId"></div>
            <div class="pe-code-actions">
                <FluentButton Appearance="Appearance.Accent"
                              @onclick="CompileCodeAsync"
                              Disabled="@_isCompiling"
                              title="Compile and save">
                    @(_isCompiling ? "Compiling…" : "Compile")
                </FluentButton>
                @if (!string.IsNullOrEmpty(_compilationStatus))
                {
                    <span class="pe-compile-status @(_compileSuccess ? "success" : "error")">
                        @_compilationStatus
                    </span>
                }
                @if (!string.IsNullOrEmpty(_compiledCid))
                {
                    <span class="pe-cid" title="IPFS CID">CID: @_compiledCid[..12]…</span>
                }
            </div>
        }
    </div>
</div>

<style>
    .property-editor {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 240px;
        background: var(--neutral-layer-3, #1c2128);
        border-left: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        z-index: 10;
        overflow: hidden;
        animation: slide-in-right 160ms ease-out;
    }

    @@keyframes slide-in-right {
        from { transform: translateX(100%); }
        to   { transform: translateX(0); }
    }

    .pe-header {
        display: flex;
        align-items: center;
        padding: 8px 10px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        gap: 8px;
        flex-shrink: 0;
    }

    .pe-title {
        flex: 1;
        font-weight: 600;
        font-size: 0.78rem;
        color: #e6edf3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pe-body {
        flex: 1;
        overflow-y: auto;
        padding: 8px 10px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .pe-section-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #484f58;
        margin-top: 10px;
        margin-bottom: 2px;
    }

    .pe-id {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.65rem;
        color: #8b949e;
        padding: 2px 6px;
        background: rgba(255,255,255,0.04);
        border-radius: 4px;
    }

    .pe-socket {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        color: #8b949e;
        padding: 2px 0;
    }

    .socket-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .pe-socket-type {
        margin-left: auto;
        font-size: 0.6rem;
        color: #484f58;
        white-space: nowrap;
    }

    .pe-empty {
        font-size: 0.68rem;
        color: #484f58;
        font-style: italic;
    }

    .pe-param {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-bottom: 6px;
    }

    .pe-param-label {
        font-size: 0.7rem;
        color: #8b949e;
        font-weight: 500;
    }

    .pe-param-hint {
        font-size: 0.62rem;
        color: #484f58;
    }

    .pe-code-editor {
        width: 100%;
        height: 240px;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 4px;
        overflow: hidden;
        background: #0d1117;
    }

    .pe-code-actions {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 6px;
        flex-wrap: wrap;
    }

    .pe-compile-status {
        font-size: 0.68rem;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .pe-compile-status.success {
        color: #2ea043;
        background: rgba(46, 160, 67, 0.12);
    }

    .pe-compile-status.error {
        color: #f85149;
        background: rgba(248, 81, 73, 0.12);
    }

    .pe-cid {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.6rem;
        color: #8b949e;
        background: rgba(255,255,255,0.04);
        padding: 2px 6px;
        border-radius: 4px;
        margin-left: auto;
    }
</style>

@code {
    [Parameter, EditorRequired] public BlockViewModel Block { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnCidChanged { get; set; }

    // ── Monaco editor state ───────────────────────────────────────────────────────

    private ElementReference _editorContainer;
    private readonly string _editorId = $"monaco-{Guid.NewGuid():N}";
    private string _currentCode  = DefaultIndicatorCode;
    private string _compilationStatus = string.Empty;
    private string _compiledCid  = string.Empty;
    private bool   _isCompiling;
    private bool   _compileSuccess;
    private DotNetObjectReference<PropertyEditor>? _dotNetRef;

    private string? _lastBlockType;
    private bool    _blockTypeChanged = true;
    private bool    _editorInitialized;

    private List<ParameterViewModel> _parameters = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _parameters = GetDefaultParameters(Block.BlockType);

        if (!string.Equals(_lastBlockType, Block.BlockType, StringComparison.Ordinal))
        {
            _lastBlockType   = Block.BlockType;
            _blockTypeChanged = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _blockTypeChanged)
        {
            await EnsureMonacoEditorStateAsync();
            _blockTypeChanged = false;
        }
    }

    private async Task EnsureMonacoEditorStateAsync()
    {
        var isCustomIndicator = string.Equals(Block.BlockType, "CustomIndicatorBlock", StringComparison.Ordinal);

        if (isCustomIndicator)
        {
            if (!_editorInitialized)
                await InitializeMonacoEditorAsync();
            return;
        }

        if (_editorInitialized)
            await DisposeMonacoEditorAsync();
    }

    private async Task InitializeMonacoEditorAsync()
    {
        // _dotNetRef must be null here: this method is only reached when !_editorInitialized.
        // The disposal guard below is a safety net for any future refactor.
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("mlsMonaco.initEditor", _editorId, _currentCode, _dotNetRef);
        _editorInitialized = true;
    }

    private async Task DisposeMonacoEditorAsync()
    {
        try { await JS.InvokeVoidAsync("mlsMonaco.disposeEditor", _editorId); }
        catch { /* ignore JS dispose errors on teardown */ }

        _dotNetRef?.Dispose();
        _dotNetRef       = null;
        _editorInitialized = false;
    }

    /// <summary>Callback invoked by Monaco JS interop when code changes (debounced 500ms).</summary>
    [JSInvokable]
    public void OnCodeChanged(string newCode)
    {
        _currentCode = newCode;
    }

    private async Task CompileCodeAsync()
    {
        if (_isCompiling) return;
        _isCompiling = true;
        _compilationStatus = string.Empty;
        _compileSuccess    = false;
        StateHasChanged();

        try
        {
            // Get the latest code from the editor
            _currentCode = await JS.InvokeAsync<string>("mlsMonaco.getCode", _editorId);

            // POST to the compile/upload endpoint — returns CID when IPFS is configured
            var request = new { Source = _currentCode, StrategyId = (Guid?)null };
            using var http = HttpClientFactory.CreateClient("designer");
            var response   = await http.PostAsJsonAsync("/api/compile/upload", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CompileApiResponse>();
                if (result?.Success == true)
                {
                    _compileSuccess    = true;
                    _compiledCid       = result.IpfsCid ?? string.Empty;
                    _compilationStatus = $"✓ Compiled in {result.ElapsedMs:F0} ms";
                    if (!string.IsNullOrEmpty(_compiledCid))
                        await OnCidChanged.InvokeAsync(_compiledCid);
                }
                else
                {
                    _compileSuccess    = false;
                    _compilationStatus = result?.Diagnostics.FirstOrDefault() ?? "Compilation failed";
                }
            }
            else
            {
                _compileSuccess    = false;
                _compilationStatus = $"HTTP {(int)response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _compileSuccess    = false;
            _compilationStatus = ex.Message;
        }
        finally
        {
            _isCompiling = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_editorInitialized)
            await DisposeMonacoEditorAsync();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────────

    private static List<ParameterViewModel> GetDefaultParameters(string blockType) => blockType switch
    {
        "RSIBlock"   => [new("Period", "14", ParameterType.Int, "RSI lookback period")],
        "MACDBlock"  => [new("FastPeriod", "12", ParameterType.Int), new("SlowPeriod", "26", ParameterType.Int), new("SignalPeriod", "9", ParameterType.Int)],
        "BollingerBlock" => [new("Period", "20", ParameterType.Int), new("StdDev", "2.0", ParameterType.Float)],
        "ATRBlock"   => [new("Period", "14", ParameterType.Int)],
        "ModelTInferenceBlock" => [new("ModelId", "", ParameterType.String, "ONNX model ID from registry")],
        "PositionSizerBlock"   => [new("RiskPerTrade", "0.01", ParameterType.Float, "Fraction of equity per trade")],
        "StopLossBlock"        => [new("StopAtr", "2.0", ParameterType.Float, "Stop distance in ATR multiples")],
        _ => [],
    };

    private static string GetSocketColor(BlockSocketType type) => type switch
    {
        BlockSocketType.CandleStream     => "#3b82f6",
        BlockSocketType.IndicatorValue   => "#06b6d4",
        BlockSocketType.IndicatorSeries  => "#67e8f9",
        BlockSocketType.MLSignal         => "#a855f7",
        BlockSocketType.RiskDecision     => "#f97316",
        BlockSocketType.TradeOrder       => "#22c55e",
        BlockSocketType.DeFiSignal       => "#14b8a6",
        BlockSocketType.HealthFactorUpdate => "#2dd4bf",
        _ => "#6b7280",
    };

        // ── Inner types ───────────────────────────────────────────────────────────────

    private enum ParameterType { Int, Float, String, Bool, Enum }

    private sealed class ParameterViewModel(string name, string defaultValue, ParameterType type, string description = "")
    {
        public string Name { get; } = name;
        public string DefaultValue { get; } = defaultValue;
        public ParameterType Type { get; } = type;
        public string Description { get; } = description;
        public string StringValue { get; set; } = defaultValue;
        public bool BoolValue { get; set; }
        public string[] Options { get; init; } = [];
    }

    private sealed record CompileApiResponse(
        bool Success,
        string? AssemblyBase64,
        IReadOnlyList<string> Diagnostics,
        string? IpfsCid,
        double ElapsedMs);
}

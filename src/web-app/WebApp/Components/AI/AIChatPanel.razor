@inject IAICanvasService AI
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="ai-chat-panel">

    @* ── Header ────────────────────────────────────────────────────────────────── *@
    <div class="acp-header">
        <div class="acp-title-row">
            <span class="acp-title-icon" aria-hidden="true">◈</span>
            <span class="acp-title">AI Assistant</span>
            <div class="acp-status @(AI.IsConnected ? "acp-status--ok" : "acp-status--offline")"
                 title="@(AI.IsConnected ? "Connected to AI Hub" : "Disconnected")">
                <span class="acp-status-dot"></span>
                @(AI.IsConnected ? "Online" : "Offline")
            </div>
        </div>

        <div class="acp-controls">
            <label class="acp-provider-label">Provider</label>
            <select class="acp-select" @bind="_providerOverride">
                <option value="">Auto</option>
                <option value="openai">OpenAI</option>
                <option value="anthropic">Anthropic</option>
                <option value="google">Google</option>
                <option value="groq">Groq</option>
                <option value="openrouter">OpenRouter</option>
                <option value="vercel">Vercel AI</option>
                <option value="local">Local / Ollama</option>
            </select>

            <button class="acp-clear-btn" @onclick="ClearHistory" title="Clear conversation">
                ✕ Clear
            </button>
        </div>
    </div>

    @* ── Message list ──────────────────────────────────────────────────────────── *@
    <div class="acp-messages" @ref="_scrollRef">
        @if (_messages.Count == 0)
        {
            <div class="acp-empty">
                <span class="acp-empty-icon" aria-hidden="true">◈</span>
                <p class="acp-empty-title">Ask anything about your trading platform</p>
                <p class="acp-empty-sub">Try: "Show BTC momentum P&L for last 30 days"</p>
            </div>
        }

        @foreach (var msg in _messages)
        {
            <MessageBubble Message="msg" />

            @foreach (var action in _canvasActionsPerMessage.GetValueOrDefault(msg.Id, []))
            {
                <CanvasActionRenderer Action="action" />
            }
        }

        @if (_isStreaming)
        {
            <div class="acp-thinking">
                <span class="acp-thinking-dot"></span>
                <span class="acp-thinking-dot"></span>
                <span class="acp-thinking-dot"></span>
            </div>
        }

        @if (_errorMessage is not null)
        {
            <div class="acp-error" role="alert">
                <span>⚠ @_errorMessage</span>
                <button @onclick="() => _errorMessage = null">✕</button>
            </div>
        }
    </div>

    @* ── Input row ─────────────────────────────────────────────────────────────── *@
    <div class="acp-input-row">
        <textarea class="acp-input"
                  @bind="_inputText"
                  @bind:event="oninput"
                  @onkeydown="OnKeyDown"
                  placeholder="Ask the AI assistant…"
                  rows="1"
                  disabled="@_isStreaming"
                  aria-label="Chat input"></textarea>

        <button class="acp-send-btn"
                @onclick="SendAsync"
                disabled="@(_isStreaming || string.IsNullOrWhiteSpace(_inputText))"
                title="Send (Enter)">
            @if (_isStreaming)
            {
                <span class="acp-send-spinner"></span>
            }
            else
            {
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M14 8L2 2l3 6-3 6 12-6z" fill="currentColor"/>
                </svg>
            }
        </button>
    </div>
</div>

<style>
    .ai-chat-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: var(--mls-bg, #07080c);
        overflow: hidden;
    }

    /* ── Header ─────────────────────────────────────────────────────────────── */
    .acp-header {
        padding: 10px 14px 8px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        flex-shrink: 0;
    }

    .acp-title-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .acp-title-icon {
        color: var(--mls-cyan, #00d4ff);
        font-size: 1rem;
    }

    .acp-title {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--mls-text, #e2e8f0);
        flex: 1;
    }

    .acp-status {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.62rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 3px 8px;
        border-radius: 20px;
    }

    .acp-status--ok {
        background: rgba(34,197,94,0.08);
        border: 1px solid rgba(34,197,94,0.2);
        color: #22c55e;
    }

    .acp-status--offline {
        background: rgba(100,116,139,0.08);
        border: 1px solid rgba(100,116,139,0.15);
        color: var(--mls-text-muted, #64748b);
    }

    .acp-status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .acp-status--ok .acp-status-dot {
        box-shadow: 0 0 4px currentColor;
        animation: dot-pulse 2s ease-in-out infinite;
    }

    @@keyframes dot-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .acp-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .acp-provider-label {
        font-size: 0.65rem;
        font-weight: 600;
        color: var(--mls-text-faint, #334155);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .acp-select {
        flex: 1;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 6px;
        color: var(--mls-text-muted, #64748b);
        font-size: 0.72rem;
        padding: 4px 8px;
        cursor: pointer;
        font-family: inherit;
        outline: none;
    }

    .acp-select:focus {
        border-color: rgba(0,212,255,0.3);
        color: var(--mls-text, #e2e8f0);
    }

    .acp-clear-btn {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 6px;
        color: var(--mls-text-faint, #334155);
        font-size: 0.65rem;
        padding: 4px 8px;
        cursor: pointer;
        font-family: inherit;
        white-space: nowrap;
        transition: color 0.12s, border-color 0.12s;
    }

    .acp-clear-btn:hover {
        color: #f85149;
        border-color: rgba(248,81,73,0.3);
    }

    /* ── Messages ─────────────────────────────────────────────────────────── */
    .acp-messages {
        flex: 1;
        overflow-y: auto;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.06) transparent;
    }

    .acp-messages::-webkit-scrollbar { width: 4px; }
    .acp-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.06); border-radius: 2px; }

    .acp-empty {
        margin: auto;
        text-align: center;
        padding: 32px 20px;
    }

    .acp-empty-icon {
        font-size: 2rem;
        color: rgba(0,212,255,0.2);
        display: block;
        margin-bottom: 12px;
    }

    .acp-empty-title {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--mls-text-muted, #64748b);
        margin: 0 0 6px;
    }

    .acp-empty-sub {
        font-size: 0.72rem;
        color: var(--mls-text-faint, #334155);
        margin: 0;
    }

    .acp-thinking {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 6px 14px;
    }

    .acp-thinking-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--mls-cyan, #00d4ff);
        opacity: 0.4;
        animation: thinking-bounce 1.2s ease-in-out infinite;
    }

    .acp-thinking-dot:nth-child(2) { animation-delay: 0.2s; }
    .acp-thinking-dot:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes thinking-bounce {
        0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
        40% { transform: translateY(-5px); opacity: 1; }
    }

    .acp-error {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: rgba(248,81,73,0.08);
        border: 1px solid rgba(248,81,73,0.2);
        border-radius: 8px;
        color: #f85149;
        font-size: 0.75rem;
    }

    .acp-error button {
        margin-left: auto;
        background: none;
        border: none;
        color: inherit;
        cursor: pointer;
        font-size: 0.75rem;
        padding: 0 2px;
        font-family: inherit;
    }

    /* ── Input row ─────────────────────────────────────────────────────────── */
    .acp-input-row {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding: 10px 14px;
        border-top: 1px solid rgba(255,255,255,0.05);
        flex-shrink: 0;
    }

    .acp-input {
        flex: 1;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 8px;
        color: var(--mls-text, #e2e8f0);
        font-size: 0.8rem;
        line-height: 1.5;
        padding: 8px 12px;
        resize: none;
        font-family: inherit;
        outline: none;
        max-height: 120px;
        overflow-y: auto;
        transition: border-color 0.15s;
    }

    .acp-input:focus {
        border-color: rgba(0,212,255,0.3);
    }

    .acp-input:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .acp-send-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(0,212,255,0.3);
        background: linear-gradient(135deg, rgba(0,212,255,0.12), rgba(124,58,237,0.12));
        color: var(--mls-cyan, #00d4ff);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.15s;
    }

    .acp-send-btn:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(0,212,255,0.22), rgba(124,58,237,0.22));
        box-shadow: 0 0 12px rgba(0,212,255,0.25);
    }

    .acp-send-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }

    .acp-send-spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(0,212,255,0.25);
        border-top-color: var(--mls-cyan, #00d4ff);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private string _inputText = "";
    private string? _providerOverride;
    private bool _isStreaming;
    private string? _errorMessage;

    private readonly List<ChatMessage> _messages = [];
    private readonly Dictionary<Guid, List<CanvasActionRecord>> _canvasActionsPerMessage = [];
    private Guid _activeMessageId = Guid.Empty;

    private ElementReference _scrollRef;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        AI.OnStateChanged += OnAIStateChanged;
        try
        {
            await AI.EnsureConnectedAsync(_cts.Token).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not connect to AI Hub: {ex.Message}";
        }
    }

    private void OnAIStateChanged()
    {
        // Canvas actions arrive asynchronously; attach them to the active message.
        if (_activeMessageId != Guid.Empty)
        {
            var newActions = AI.RecentActions
                .Where(a => !_canvasActionsPerMessage
                    .GetValueOrDefault(_activeMessageId, [])
                    .Any(x => x.Timestamp == a.Timestamp && x.ActionType == a.ActionType))
                .ToList();

            if (newActions.Count > 0)
            {
                if (!_canvasActionsPerMessage.TryGetValue(_activeMessageId, out var list))
                {
                    list = [];
                    _canvasActionsPerMessage[_activeMessageId] = list;
                }
                list.AddRange(newActions);
            }
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task SendAsync()
    {
        var query = _inputText.Trim();
        if (string.IsNullOrEmpty(query) || _isStreaming) return;

        _inputText = "";
        _errorMessage = null;

        // Build history from prior completed turns BEFORE adding the current user message
        // so the query is not duplicated (AI Hub appends query.Query as the final user turn).
        var history = BuildHistory();

        var userMsg = new ChatMessage(
            Id: Guid.NewGuid(),
            Role: "user",
            Content: query,
            IsStreaming: false,
            Timestamp: DateTimeOffset.UtcNow);

        _messages.Add(userMsg);

        var assistantMsg = new ChatMessage(
            Id: Guid.NewGuid(),
            Role: "assistant",
            Content: "",
            IsStreaming: true,
            Timestamp: DateTimeOffset.UtcNow);

        _messages.Add(assistantMsg);
        _activeMessageId = assistantMsg.Id;
        _isStreaming = true;

        StateHasChanged();
        await ScrollToBottomAsync();

        _ = StreamResponseAsync(assistantMsg, history, query);
    }

    private async Task StreamResponseAsync(
        ChatMessage assistantMsg,
        IReadOnlyList<System.Text.Json.JsonElement> history,
        string query)
    {
        try
        {
            await AI.SendQueryAsync(query, _providerOverride, null, history, _cts.Token)
                .ConfigureAwait(false);

            var contentBuilder = new System.Text.StringBuilder();
            await foreach (var chunk in AI.ReadChunksAsync(_cts.Token).ConfigureAwait(false))
            {
                contentBuilder.Append(chunk.Text);
                var updated = assistantMsg with
                {
                    Content = contentBuilder.ToString(),
                    IsStreaming = !chunk.IsFinal,
                };

                var idx = _messages.FindIndex(m => m.Id == assistantMsg.Id);
                if (idx >= 0) _messages[idx] = updated;
                assistantMsg = updated;

                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
                await ScrollToBottomAsync().ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException) { /* component disposed */ }
        catch (Exception ex)
        {
            _errorMessage = $"AI error: {ex.Message}";
            var idx = _messages.FindIndex(m => m.Id == assistantMsg.Id);
            if (idx >= 0)
            {
                _messages[idx] = assistantMsg with { IsStreaming = false };
            }
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        finally
        {
            _isStreaming = false;
            _activeMessageId = Guid.Empty;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key != "Enter" || args.ShiftKey)
            return;

        // Strip any trailing newline the browser may have already inserted before the
        // keydown event propagated (the query is also trimmed in SendAsync, but stripping
        // here prevents a brief stale newline in the bound textarea).
        _inputText = _inputText.TrimEnd('\r', '\n');
        await SendAsync();
    }

    private void ClearHistory()
    {
        _messages.Clear();
        _canvasActionsPerMessage.Clear();
        _activeMessageId = Guid.Empty;
        _errorMessage = null;
        StateHasChanged();
    }

    private IReadOnlyList<System.Text.Json.JsonElement> BuildHistory()
    {
        // Return the last 10 completed turns. Called before the current user message is
        // added to _messages, so the current query is not duplicated in history.
        return _messages
            .Where(m => !m.IsStreaming)
            .TakeLast(10)
            .Select(m => System.Text.Json.JsonSerializer.SerializeToElement(new
            {
                role = m.Role,
                content = m.Content,
            }))
            .ToList();
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollElementToBottom", _scrollRef).ConfigureAwait(false);
        }
        catch (JSException) { /* non-fatal */ }
    }

    public async ValueTask DisposeAsync()
    {
        AI.OnStateChanged -= OnAIStateChanged;
        await _cts.CancelAsync().ConfigureAwait(false);
        _cts.Dispose();
    }
}

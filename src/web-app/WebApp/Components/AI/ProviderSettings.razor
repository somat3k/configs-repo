@inject IConfiguration Configuration
@inject ILogger<ProviderSettings> Logger
@implements IDisposable

<div class="provider-settings">

    <div class="ps-header">
        <span class="ps-title">LLM Provider Settings</span>
        <span class="ps-sub">Configure AI Hub providers and preferences</span>
    </div>

    @if (_saved)
    {
        <div class="ps-banner ps-banner--ok" role="status">
            ✓ Settings saved
        </div>
    }

    @if (_errorMessage is not null)
    {
        <div class="ps-banner ps-banner--err" role="alert">
            ⚠ @_errorMessage
            <button @onclick="() => _errorMessage = null">✕</button>
        </div>
    }

    <div class="ps-section-title">Active Providers</div>

    <div class="ps-providers">
        @foreach (var p in _providers)
        {
            var provider = p;
            <div class="ps-card @(provider.Enabled ? "ps-card--enabled" : "")">
                <div class="ps-card-header">
                    <div class="ps-card-name-row">
                        <span class="ps-card-icon" aria-hidden="true">@provider.Icon</span>
                        <span class="ps-card-name">@provider.DisplayName</span>
                        @if (provider.IsLocal)
                        {
                            <span class="ps-badge ps-badge--local">Local</span>
                        }
                    </div>
                    <label class="ps-toggle" title="@(provider.Enabled ? "Disable" : "Enable")">
                        <input type="checkbox"
                               checked="@provider.Enabled"
                               @onchange="() => provider.Enabled = !provider.Enabled" />
                        <span class="ps-toggle-track"></span>
                    </label>
                </div>

                @if (provider.Enabled)
                {
                    <div class="ps-card-body">
                        @if (!provider.IsLocal)
                        {
                            <div class="ps-field">
                                <label class="ps-field-label">API Key</label>
                                <input class="ps-input"
                                       type="password"
                                       placeholder="sk-…"
                                       @bind="provider.ApiKey"
                                       autocomplete="off" />
                            </div>
                        }
                        else
                        {
                            <div class="ps-field">
                                <label class="ps-field-label">Endpoint URL</label>
                                <input class="ps-input"
                                       type="url"
                                       placeholder="http://localhost:11434"
                                       @bind="provider.Endpoint" />
                            </div>
                        }

                        <div class="ps-field">
                            <label class="ps-field-label">Default Model</label>
                            <input class="ps-input"
                                   type="text"
                                   placeholder="@provider.DefaultModelHint"
                                   @bind="provider.ModelId" />
                        </div>

                        <div class="ps-field ps-field--row">
                            <label class="ps-field-label">Primary</label>
                            <input type="radio"
                                   name="primary-provider"
                                   value="@provider.Id"
                                   checked="@(_primaryProviderId == provider.Id)"
                                   @onchange="() => _primaryProviderId = provider.Id" />
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="ps-section-title">Fallback Chain</div>
    <div class="ps-fallback-info">
        Providers are tried in order when the primary fails.
        Drag to reorder (future feature). Current order: <strong>@string.Join(" → ", _providers.Where(p => p.Enabled).Select(p => p.DisplayName))</strong>
    </div>

    <div class="ps-actions">
        <button class="ps-btn ps-btn--primary"
                @onclick="SaveAsync"
                disabled="@_saving">
            @if (_saving)
            {
                <span class="ps-spinner"></span>
            }
            Save Settings
        </button>

        <button class="ps-btn ps-btn--secondary" @onclick="ResetDefaults">
            Reset to Defaults
        </button>
    </div>
</div>

<style>
    .provider-settings {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow-y: auto;
        padding: 16px;
        gap: 12px;
        background: var(--mls-bg, #07080c);
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.06) transparent;
    }

    .ps-header {
        margin-bottom: 4px;
    }

    .ps-title {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--mls-text, #e2e8f0);
    }

    .ps-sub {
        display: block;
        font-size: 0.72rem;
        color: var(--mls-text-muted, #64748b);
        margin-top: 2px;
    }

    .ps-banner {
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ps-banner--ok {
        background: rgba(34,197,94,0.08);
        border: 1px solid rgba(34,197,94,0.2);
        color: #22c55e;
    }

    .ps-banner--err {
        background: rgba(248,81,73,0.08);
        border: 1px solid rgba(248,81,73,0.2);
        color: #f85149;
    }

    .ps-banner--err button {
        margin-left: auto;
        background: none;
        border: none;
        color: inherit;
        cursor: pointer;
        font-family: inherit;
        font-size: 0.75rem;
        padding: 0 2px;
    }

    .ps-section-title {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--mls-text-faint, #334155);
        padding-bottom: 6px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .ps-providers {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .ps-card {
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 8px;
        overflow: hidden;
        background: rgba(255,255,255,0.02);
        transition: border-color 0.15s;
    }

    .ps-card--enabled {
        border-color: rgba(0,212,255,0.12);
    }

    .ps-card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
    }

    .ps-card-name-row {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ps-card-icon {
        font-size: 0.9rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
        color: var(--mls-cyan, #00d4ff);
    }

    .ps-card-name {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--mls-text, #e2e8f0);
    }

    .ps-badge {
        font-size: 0.58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .ps-badge--local {
        background: rgba(124,58,237,0.15);
        border: 1px solid rgba(124,58,237,0.25);
        color: #a78bfa;
    }

    /* Toggle switch */
    .ps-toggle {
        position: relative;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    .ps-toggle input { display: none; }

    .ps-toggle-track {
        width: 32px;
        height: 18px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 9px;
        position: relative;
        transition: background 0.2s, border-color 0.2s;
    }

    .ps-toggle-track::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        transition: transform 0.2s, background 0.2s;
    }

    .ps-toggle input:checked ~ .ps-toggle-track {
        background: rgba(0,212,255,0.2);
        border-color: rgba(0,212,255,0.4);
    }

    .ps-toggle input:checked ~ .ps-toggle-track::after {
        transform: translateX(14px);
        background: var(--mls-cyan, #00d4ff);
    }

    .ps-card-body {
        padding: 0 12px 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        border-top: 1px solid rgba(255,255,255,0.04);
    }

    .ps-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .ps-field--row {
        flex-direction: row;
        align-items: center;
    }

    .ps-field-label {
        font-size: 0.65rem;
        font-weight: 600;
        color: var(--mls-text-faint, #334155);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ps-input {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 6px;
        color: var(--mls-text, #e2e8f0);
        font-size: 0.75rem;
        padding: 6px 10px;
        font-family: inherit;
        outline: none;
        transition: border-color 0.15s;
    }

    .ps-input:focus {
        border-color: rgba(0,212,255,0.3);
    }

    .ps-fallback-info {
        font-size: 0.72rem;
        color: var(--mls-text-muted, #64748b);
        line-height: 1.5;
    }

    .ps-fallback-info strong {
        color: var(--mls-cyan, #00d4ff);
    }

    .ps-actions {
        display: flex;
        gap: 8px;
        padding-top: 4px;
    }

    .ps-btn {
        padding: 8px 16px;
        border-radius: 7px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.15s;
    }

    .ps-btn--primary {
        background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(124,58,237,0.15));
        border: 1px solid rgba(0,212,255,0.25);
        color: var(--mls-cyan, #00d4ff);
    }

    .ps-btn--primary:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(0,212,255,0.25), rgba(124,58,237,0.25));
        box-shadow: 0 0 12px rgba(0,212,255,0.2);
    }

    .ps-btn--primary:disabled { opacity: 0.5; cursor: not-allowed; }

    .ps-btn--secondary {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        color: var(--mls-text-muted, #64748b);
    }

    .ps-btn--secondary:hover {
        background: rgba(255,255,255,0.06);
        color: var(--mls-text, #e2e8f0);
    }

    .ps-spinner {
        width: 12px;
        height: 12px;
        border: 2px solid rgba(0,212,255,0.2);
        border-top-color: var(--mls-cyan, #00d4ff);
        border-radius: 50%;
        animation: ps-spin 0.7s linear infinite;
    }

    @@keyframes ps-spin { to { transform: rotate(360deg); } }
</style>

@code {
    private string? _primaryProviderId = "openai";
    private bool _saving;
    private bool _saved;
    private string? _errorMessage;
    private System.Threading.CancellationTokenSource _cts = new();

    private List<ProviderEntry> _providers = [];

    protected override void OnInitialized()
    {
        _providers =
        [
            new("openai",      "OpenAI",         "◈", false, "gpt-4o"),
            new("anthropic",   "Anthropic",       "◉", false, "claude-3-5-sonnet-20241022"),
            new("google",      "Google Gemini",   "◎", false, "gemini-1.5-pro"),
            new("groq",        "Groq",            "⚡", false, "llama-3.1-70b-versatile"),
            new("openrouter",  "OpenRouter",      "◬", false, "openai/gpt-4o"),
            new("vercel",      "Vercel AI",       "△", false, "gpt-4o"),
            new("local",       "Local / Ollama",  "⬡", true,  "llama3.2"),
        ];
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _saved = false;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var aiHubUrl = Configuration["MLS:Network:AIHubUrl"] ?? "http://ai-hub:5750";
            using var http = new System.Net.Http.HttpClient();
            http.BaseAddress = new Uri(aiHubUrl);
            http.Timeout = TimeSpan.FromSeconds(10);

            var body = new
            {
                primary_provider_id    = _primaryProviderId ?? "openai",
                preferred_model_id     = _providers.FirstOrDefault(p => p.Id == _primaryProviderId)?.ModelId ?? "",
                fallback_chain         = _providers.Where(p => p.Enabled && p.Id != _primaryProviderId)
                                                   .Select(p => p.Id)
                                                   .ToArray(),
            };

            var response = await http.PostAsJsonAsync("/api/preferences", body, _cts.Token)
                .ConfigureAwait(false);

            if (response.IsSuccessStatusCode)
                _saved = true;
            else
                _errorMessage = $"Save failed: HTTP {(int)response.StatusCode}";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ProviderSettings save failed");
            _errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private void ResetDefaults()
    {
        foreach (var p in _providers)
        {
            p.ApiKey = "";
            p.ModelId = "";
            p.Enabled = false;
        }
        if (_providers.Count > 0) _providers[0].Enabled = true;
        _primaryProviderId = _providers[0].Id;
        _saved = false;
        _errorMessage = null;
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    // ── Model ──────────────────────────────────────────────────────────────────

    private sealed class ProviderEntry(
        string id,
        string displayName,
        string icon,
        bool isLocal,
        string defaultModelHint)
    {
        public string Id             { get; } = id;
        public string DisplayName    { get; } = displayName;
        public string Icon           { get; } = icon;
        public bool IsLocal          { get; } = isLocal;
        public string DefaultModelHint { get; } = defaultModelHint;

        public bool Enabled   { get; set; } = id is "openai" or "local";
        public string ApiKey  { get; set; } = "";
        public string ModelId { get; set; } = "";
        public string Endpoint { get; set; } = isLocal ? "http://localhost:11434" : "";
    }
}

@inherits LayoutComponentBase
@inject WindowManager WM

<FluentDesignTheme Mode="DesignThemeModes.Dark" />

@* ── Mobile nav drawer overlay ──────────────────────────────────────────── *@
@if (_navOpen)
{
    <div class="nav-drawer-overlay nav-drawer-overlay--open"
         @onclick="CloseNav"
         aria-hidden="true"></div>
}

@* ── Mobile slide-in drawer ──────────────────────────────────────────────── *@
<nav class="nav-drawer @(_navOpen ? "nav-drawer--open" : "")"
     aria-label="Mobile navigation"
     aria-hidden="@(!_navOpen)">
    <div class="nav-brand">
        <div class="nav-brand-logo">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <path d="M14 2L26 8v12L14 26 2 20V8L14 2z"
                      fill="none" stroke="url(#brand-grad-d)" stroke-width="1.5"/>
                <path d="M8 14l4 4 8-8" stroke="url(#brand-grad-d)" stroke-width="2" stroke-linecap="round"/>
                <defs>
                    <linearGradient id="brand-grad-d" x1="2" y1="2" x2="26" y2="26" gradientUnits="userSpaceOnUse">
                        <stop offset="0%" stop-color="#00d4ff"/>
                        <stop offset="100%" stop-color="#7c3aed"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>
        <div class="nav-brand-text">
            <span class="nav-brand-name">MLS</span>
            <span class="nav-brand-sub">Trading Platform</span>
        </div>
    </div>
    <FluentNavMenu Width="240" class="mls-fluent-nav">
        @RenderNavLinks()
    </FluentNavMenu>
    <div class="nav-footer">
        <div class="nav-status-dot"></div>
        <span class="nav-status-text">Live</span>
    </div>
</nav>

<div class="mls-shell">
    @* ── Desktop sidebar nav ──────────────────────────────────────────────── *@
    <nav class="mls-nav" aria-label="Desktop navigation">
        @* ── Brand strip ──────────────────────────────────────────────────── *@
        <div class="nav-brand">
            <div class="nav-brand-logo">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <path d="M14 2L26 8v12L14 26 2 20V8L14 2z"
                          fill="none" stroke="url(#brand-grad)" stroke-width="1.5"/>
                    <path d="M8 14l4 4 8-8" stroke="url(#brand-grad)" stroke-width="2" stroke-linecap="round"/>
                    <defs>
                        <linearGradient id="brand-grad" x1="2" y1="2" x2="26" y2="26" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#00d4ff"/>
                            <stop offset="100%" stop-color="#7c3aed"/>
                        </linearGradient>
                    </defs>
                </svg>
            </div>
            <div class="nav-brand-text">
                <span class="nav-brand-name">MLS</span>
                <span class="nav-brand-sub">Trading Platform</span>
            </div>
        </div>

        <FluentNavMenu Width="220" class="mls-fluent-nav">
            @RenderNavLinks()
        </FluentNavMenu>

        <div class="nav-footer">
            <div class="nav-status-dot"></div>
            <span class="nav-status-text">Live</span>
        </div>
    </nav>

    <main class="mls-main">
        @* ── Mobile top bar ───────────────────────────────────────────────── *@
        <div class="mobile-topbar">
            <button class="hamburger-btn"
                    @onclick="ToggleNav"
                    aria-label="@(_navOpen ? "Close navigation" : "Open navigation")"
                    aria-expanded="@_navOpen">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    @if (_navOpen)
                    {
                        <line x1="3" y1="3" x2="15" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <line x1="15" y1="3" x2="3" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    }
                    else
                    {
                        <line x1="3" y1="5"  x2="15" y2="5"  stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <line x1="3" y1="9"  x2="15" y2="9"  stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <line x1="3" y1="13" x2="15" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    }
                </svg>
            </button>
            <span class="mobile-topbar-title">MLS Trading Platform</span>
            <div class="nav-status-dot" style="margin-left:auto;"></div>
        </div>

        @Body
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentMessageBarProvider />
<FluentTooltipProvider />

<style>
    .mls-shell {
        display: flex;
        height: 100vh;
        overflow: hidden;
        background: var(--mls-bg, #07080c);
    }

    /* ── Sidebar nav ─────────────────────────────────────────────────────── */
    .mls-nav {
        width: 220px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        background: var(--mls-surface, #0e1018);
        border-right: 1px solid rgba(255,255,255,0.05);
        overflow-y: auto;
        overflow-x: hidden;
        position: relative;
    }

    /* Subtle left-edge glow */
    .mls-nav::after {
        content: '';
        position: absolute;
        right: 0; top: 0; bottom: 0;
        width: 1px;
        background: linear-gradient(180deg, transparent 0%, rgba(0,212,255,0.2) 40%, rgba(124,58,237,0.2) 70%, transparent 100%);
        pointer-events: none;
    }

    /* ── Brand ────────────────────────────────────────────────────────────── */
    .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px 16px 16px;
        flex-shrink: 0;
    }

    .nav-brand-logo {
        width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(0,212,255,0.08), rgba(124,58,237,0.08));
        border: 1px solid rgba(0,212,255,0.2);
        border-radius: 10px;
        flex-shrink: 0;
    }

    .nav-brand-text { display: flex; flex-direction: column; line-height: 1.2; }
    .nav-brand-name {
        font-size: 0.9rem;
        font-weight: 700;
        background: linear-gradient(135deg, #00d4ff, #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: 0.05em;
    }
    .nav-brand-sub {
        font-size: 0.6rem;
        color: var(--mls-text-faint, #334155);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    /* ── Section labels ───────────────────────────────────────────────────── */
    .nav-section-label {
        font-size: 0.55rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mls-text-faint, #334155);
        padding: 12px 16px 4px;
        flex-shrink: 0;
    }

    /* ── Nav icons ───────────────────────────────────────────────────────── */
    .nav-icon {
        font-size: 0.9rem;
        width: 18px;
        text-align: center;
        flex-shrink: 0;
    }
    .nav-icon--trading  { color: #22c55e; }
    .nav-icon--arb      { color: #f59e0b; }
    .nav-icon--defi     { color: #7c3aed; }
    .nav-icon--designer { color: #00d4ff; }
    .nav-icon--ml       { color: #ec4899; }

    /* ── Footer ──────────────────────────────────────────────────────────── */
    .nav-footer {
        margin-top: auto;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 12px 16px;
        border-top: 1px solid rgba(255,255,255,0.04);
    }
    .nav-status-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 6px #22c55e;
        animation: live-pulse 1.5s ease-in-out infinite;
    }
    .nav-status-text {
        font-size: 0.6rem;
        font-weight: 600;
        color: #22c55e;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    /* ── Main ─────────────────────────────────────────────────────────────── */
    .mls-main {
        flex: 1;
        overflow: hidden;
        position: relative;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

    /* ── Mobile top bar ──────────────────────────────────────────────────── */
    .mobile-topbar-title {
        font-size: 0.82rem;
        font-weight: 600;
        background: linear-gradient(135deg, #00d4ff, #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>

@code {
    [Inject] private IJSRuntime? JS { get; set; }

    private bool _navOpen;

    private void ToggleNav() => _navOpen = !_navOpen;

    private void CloseNav() => _navOpen = false;

    private RenderFragment RenderNavLinks() =>
        @<text>
            <FluentNavLink Href="/" Match="NavLinkMatch.All">
                Dashboard
            </FluentNavLink>

            <FluentNavGroup Title="Trading">
                <FluentNavLink @onclick='() => OpenPanelAndClose("TradingTerminal", "Trading Terminal")'>
                    Terminal
                </FluentNavLink>
                <FluentNavLink @onclick='() => OpenPanelAndClose("TradingChart", "Chart")'>
                    Chart
                </FluentNavLink>
            </FluentNavGroup>

            <FluentNavGroup Title="Arbitrage">
                <FluentNavLink @onclick='() => OpenPanelAndClose("ArbitrageScanner", "Arbitrage Scanner")'>
                    Scanner
                </FluentNavLink>
                <FluentNavLink @onclick='() => OpenPanelAndClose("PathVisualization", "Path Graph")'>
                    Path Graph
                </FluentNavLink>
            </FluentNavGroup>

            <FluentNavGroup Title="DeFi">
                <FluentNavLink @onclick='() => OpenPanelAndClose("DeFiPositions", "DeFi Positions")'>
                    Positions
                </FluentNavLink>
                <FluentNavLink @onclick='() => OpenPanelAndClose("HealthMonitor", "Health Monitor")'>
                    Health Monitor
                </FluentNavLink>
            </FluentNavGroup>

            <FluentNavGroup Title="Designer">
                <FluentNavLink @onclick='() => OpenPanelAndClose("DesignerCanvas", "Strategy Designer")'>
                    Canvas
                </FluentNavLink>
            </FluentNavGroup>

            <FluentNavGroup Title="ML">
                <FluentNavLink Href="/ml">
                    Model Registry
                </FluentNavLink>
            </FluentNavGroup>

            <FluentNavGroup Title="AI">
                <FluentNavLink @onclick='() => OpenPanelAndClose("AIChatPanel", "AI Assistant")'>
                    AI Assistant
                </FluentNavLink>
                <FluentNavLink @onclick='() => OpenPanelAndClose("ProviderSettings", "AI Providers")'>
                    Providers
                </FluentNavLink>
            </FluentNavGroup>
        </text>;

    private void OpenPanelAndClose(string panelType, string title)
    {
        WM.OpenPanel(panelType, title);
        _navOpen = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var width = await JS!.InvokeAsync<double>("mlsViewport.getInnerWidth")
                .ConfigureAwait(false);
            _ = width; // nav collapse driven by CSS media queries
        }
        catch { /* non-critical */ }
    }
}

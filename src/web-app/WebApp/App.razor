<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MLS Trading Platform</title>
    <base href="/" />
    <meta name="application-name" content="MLS Trading Platform" />
    <meta name="theme-color" content="#00d4ff" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MLS" />
    <link rel="manifest" href="manifest.json" />
    <link rel="apple-touch-icon" href="icons/icon-maskable-192.svg" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/responsive.css" />
    <link rel="icon" type="image/svg+xml" href="icons/icon-192.svg" />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"
            integrity="sha384-XR2/wZ8LjLQG4DqeRjW1Xw0/cqjM8M7Z5qX6Ch12HaxDTXiiMHDL/95B2S/bR5CV"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.49.1/dist/apexcharts.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/cytoscape@3.29.2/dist/cytoscape.min.js"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10.9.1/dist/mermaid.min.js"
            crossorigin="anonymous"></script>
    <script src="js/canvas-interop.js"></script>
    <script src="service-worker-assets.js"></script>
    <script>
        // Register MLS service worker
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/service-worker.js', { scope: '/' })
                    .then(function (reg) {
                        console.log('[MLS SW] registered, scope:', reg.scope);
                    })
                    .catch(function (err) {
                        console.warn('[MLS SW] registration failed:', err);
                    });
            });
        }
    </script>
</body>
</html>

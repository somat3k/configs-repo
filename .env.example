# Environment variables — copy to .env and fill in values
# NEVER commit .env to git

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=devdb

# ─── IPFS ─────────────────────────────────────────────────────────────────────
IPFS_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080

# ─── Service Bus ──────────────────────────────────────────────────────────────
BUS_URL=ws://localhost:9000/bus

# ─── GitHub (for MCP server) ──────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Linear (for MCP server) ──────────────────────────────────────────────────
LINEAR_API_KEY=

# ─── Solidity / Hardhat ───────────────────────────────────────────────────────
SEPOLIA_RPC_URL=
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# MLS Trading Platform — Environment Variables
# Copy this file to .env and fill in values

# PostgreSQL
POSTGRES_USER=mls_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mls_db

# Redis
REDIS_PASSWORD=

# IPFS
IPFS_API_URL=http://localhost:5001

# pgAdmin (dev tools)
PGADMIN_EMAIL=admin@mls.local
PGADMIN_PASSWORD=admin

# Module URLs (override for custom network setups)
MLS_BC_URL=http://localhost:5100
MLS_TRADER_URL=http://localhost:5300
MLS_ARBITRAGER_URL=http://localhost:5400
MLS_DEFI_URL=http://localhost:5500
MLS_ML_URL=http://localhost:5600
MLS_DATA_URL=http://localhost:5700

# HYPERLIQUID (Primary Broker)
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_PAPER_TRADING=true

# Broker Fallback 1
BROKER1_API_URL=
BROKER1_API_KEY=

# Broker Fallback 2
BROKER2_API_URL=
BROKER2_API_KEY=

# AI/ML
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# GitHub Container Registry
GHCR_TOKEN=

# Application
ASPNETCORE_ENVIRONMENT=Development
MLS_ENV=development

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🔵 Block Controller (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "🏗️ Build All",
      "program": "${workspaceFolder}/src/block-controller/BlockController/bin/Debug/net9.0/BlockController.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/block-controller/BlockController",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5100",
        "MLS_MODULE": "block-controller",
        "MLS_WS_PORT": "6100"
      },
      "console": "integratedTerminal",
      "sourceFileMap": { "/Views": "${workspaceFolder}/Views" }
    },
    {
      "name": "🌐 Web App (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "🏗️ Build All",
      "program": "${workspaceFolder}/src/web-app/WebApp/bin/Debug/net9.0/WebApp.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/web-app/WebApp",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7200;http://localhost:5200",
        "MLS_MODULE": "web-app"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "📊 Trader Module (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "🏗️ Build All",
      "program": "${workspaceFolder}/src/modules/trader/Trader/bin/Debug/net9.0/Trader.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/modules/trader/Trader",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5300",
        "MLS_MODULE": "trader",
        "MLS_WS_PORT": "6300"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "🔄 Arbitrager Module (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "🏗️ Build All",
      "program": "${workspaceFolder}/src/modules/arbitrager/Arbitrager/bin/Debug/net9.0/Arbitrager.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/modules/arbitrager/Arbitrager",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5400",
        "MLS_MODULE": "arbitrager",
        "MLS_WS_PORT": "6400"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "⛓️ DeFi Module (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "🏗️ Build All",
      "program": "${workspaceFolder}/src/modules/defi/DeFi/bin/Debug/net9.0/DeFi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/modules/defi/DeFi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5500",
        "MLS_MODULE": "defi",
        "MLS_WS_PORT": "6500"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "🔬 Attach to Process",
      "type": "coreclr",
      "request": "attach",
      "processName": "dotnet"
    },
    {
      "name": "🐍 Python ML Service (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/modules/ml-runtime/main.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/modules/ml-runtime",
        "MLS_MODULE": "ml-runtime",
        "MLS_WS_PORT": "6600"
      }
    },
    {
      "name": "🌍 NuxtJS Dev (Browser)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/nuxt-pages",
      "preLaunchTask": "🌍 Run NuxtJS Dev Server"
    }
  ],
  "compounds": [
    {
      "name": "🚀 Full Stack (All Modules)",
      "configurations": [
        "🔵 Block Controller (Debug)",
        "🌐 Web App (Debug)",
        "📊 Trader Module (Debug)",
        "🔄 Arbitrager Module (Debug)",
        "⛓️ DeFi Module (Debug)"
      ],
      "stopAll": true,
      "preLaunchTask": "🐳 Start Infrastructure"
    }
  ]
}

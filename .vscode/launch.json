{
  "version": "0.2.0",
  "configurations": [
    // ─── Rust ────────────────────────────────────────────────────────────────
    {
      "type": "lldb",
      "request": "launch",
      "name": "Rust: Debug (select bin)",
      "cargo": { "args": ["build"] },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Rust: Debug unit tests",
      "cargo": { "args": ["test", "--no-run", "--lib"] },
      "args": [],
      "cwd": "${workspaceFolder}"
    },

    // ─── Python ──────────────────────────────────────────────────────────────
    {
      "name": "Python: Run module",
      "type": "debugpy",
      "request": "launch",
      "module": "project",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": { "PYTHONPATH": "${workspaceFolder}/src" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },

    // ─── Solidity (Ape Framework) ─────────────────────────────────────────────
    {
      "name": "Ape: compile contracts",
      "type": "debugpy",
      "request": "launch",
      "module": "ape",
      "args": ["compile"],
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },

    // ─── Docker attach ────────────────────────────────────────────────────────
    {
      "name": "Docker: Attach to container",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/app"
        }
      ]
    }
  ],

  "compounds": [
    {
      "name": "Full stack",
      "configurations": ["Rust: Debug (select bin)", "Python: Run module"]
    }
  ]
}
